{
  "name": "project-inspire",
  "version": "1.1.0",
  "description": "Inclusive education lesson planning application",
  "author": "Gezyne-Jamir Software Tech",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "concurrently -k -n backend,frontend \"npm --prefix backend run start\" \"npm --prefix frontend run start\"",
    "dev": "npm run start",
    "ng:serve": "npm --prefix frontend run start",
    "electron:dev": "cross-env INSPIRE_DEV_SERVER_URL=http://localhost:4200 electron .",
    "electron:test": "node scripts/start-electron-dev.js",
    "icon:win": "node scripts/generate-win-icon.js",
    "build:frontend": "npm --prefix frontend run build",
    "build:installer": "npm run icon:win && npm run build:frontend && electron-builder --config electron-builder.yml",
    "build:electron": "npm run build:installer"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/xai": "^3.0.83",
    "ai": "^6.0.168",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.2"
  }
}