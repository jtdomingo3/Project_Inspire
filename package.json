{
  "name": "project-inspire",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "concurrently -k -n backend,frontend \"npm --prefix backend run start\" \"npm --prefix frontend run start\"",
    "dev": "npm run start",
    "electron": "electron .",
    "build:frontend": "npm --prefix frontend run build",
    "build:electron": "npm run build:frontend && electron-builder",
    "electron:dev": "concurrently -k -n backend,electron \"npm --prefix backend run start\" \"electron .\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
