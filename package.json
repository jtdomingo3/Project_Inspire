{
  "name": "project-inspire",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "concurrently -k -n backend,frontend \"npm --prefix backend run start\" \"npm --prefix frontend run start\"",
    "dev": "npm run start",
    "ng:serve": "npm --prefix frontend run start",
    "electron:dev": "cross-env INSPIRE_DEV_SERVER_URL=http://localhost:4200 electron .",
    "build:frontend": "npm --prefix frontend run build",
    "build:electron": "npm run build:frontend && electron-builder --config electron-builder.yml"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.1",
    "electron-builder": "^25.1.8"
  }
}
